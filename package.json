{
  "name": "manbot",
  "description": "Manbot is a chatbot that can help you with your daily tasks.",
  "type": "module",
  "module": "src/index.ts",
  "license": "GPL-3.0",
  "version": "0.5.9",
  "scripts": {
    "dev": "bun run --inspect=/bun src/index.ts",
    "build": "bun run src/build.ts",
    "tsc": "tsc --noEmit",
    "format": "prettier --write src/",
    "release": "bun tsc && bun format && commit-and-tag-version && git push --follow-tags"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.36",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.3.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@seepine/cache": "^0.1.3",
    "axios": "^1.13.6",
    "cron-parser": "^5.5.0",
    "dayjs": "^1.11.19",
    "elysia": "^1.4.26",
    "js-yaml": "^4.1.1",
    "langchain": "^1.2.37",
    "lodash-es": "^4.17.23",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "systeminformation": "^5.31.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash-es": "^4.17.12",
    "commit-and-tag-version": "^12.7.1",
    "prettier": "^3.8.1",
    "typescript": "^5"
  }
}
